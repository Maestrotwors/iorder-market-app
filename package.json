{
  "name": "iorder-market-app",
  "version": "0.0.1",
  "private": true,
  "description": "iOrder Market — e-commerce platform with microservices architecture",
  "workspaces": [
    "packages/*",
    "microservices/*"
  ],
  "scripts": {
    "start:web": "ng serve web",
    "start:frontend": "bun run start:web",
    "start:gateway": "cd microservices/api-gateway && bun run dev",
    "start:products": "cd microservices/products-service && bun run dev",
    "start:microservices": "concurrently \"bun run start:gateway\" \"bun run start:products\"",
    "start:all": "concurrently \"bun run start:microservices\" \"bun run start:frontend\"",
    "build:web": "ng build web",
    "db:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down"
  },
  "dependencies": {
    "@angular/animations": "latest",
    "@angular/common": "latest",
    "@angular/compiler": "latest",
    "@angular/core": "latest",
    "@angular/forms": "latest",
    "@angular/platform-browser": "latest",
    "@angular/platform-browser-dynamic": "latest",
    "@angular/router": "latest",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@angular/build": "latest",
    "@angular/cli": "latest",
    "@angular/compiler-cli": "latest",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "prisma"
  ]
}
