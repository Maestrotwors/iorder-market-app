{
  "name": "iorder-market-app",
  "version": "0.0.1",
  "private": true,
  "description": "iOrder Market — e-commerce platform",
  "workspaces": [
    "packages/*",
    "microservices/*"
  ],
  "scripts": {
    "start:web": "ng serve web",
    "start:frontend": "bun run start:web",
    "start:gateway": "cd microservices/api-gateway && bun run dev",
    "start:products": "cd microservices/products-service && bun run dev",
    "start:microservices": "concurrently \"bun run start:gateway\" \"bun run start:products\"",
    "start:all": "concurrently \"bun run start:microservices\" \"bun run start:frontend\"",
    "build:web": "ng build web",
    "db:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json}\"",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check": "bun run format:check && bun run lint && bun run knip",
    "check:fix": "bun run format && bun run lint:fix && bun run knip:fix",
    "prebuild:web": "bun run check"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/node": "^22.0.0",
    "angular-eslint": "^21.3.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "knip": "^5.88.0",
    "prettier": "^3.8.1",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "prisma"
  ]
}
