{
  "dependencies": {
    "@angular/animations": "latest",
    "@softarc/native-federation-node": "^3.3.4",
    "es-module-shims": "^1.5.12"
  },
  "name": "iorder-market-app",
  "version": "0.0.1",
  "private": true,
  "description": "iOrder Market — e-commerce platform with microservices architecture",
  "workspaces": [
    "packages/*",
    "microservices/*"
  ],
  "scripts": {
    "start:shell": "ng serve shell",
    "start:customer": "ng serve customer",
    "start:supplier": "ng serve supplier",
    "start:admin": "ng serve admin",
    "start:frontend": "concurrently \"bun run start:shell\" \"bun run start:customer\" \"bun run start:supplier\" \"bun run start:admin\"",
    "start:gateway": "cd microservices/api-gateway && bun run dev",
    "start:products": "cd microservices/products-service && bun run dev",
    "start:microservices": "concurrently \"bun run start:gateway\" \"bun run start:products\"",
    "start:all": "concurrently \"bun run start:microservices\" \"bun run start:frontend\"",
    "build:shell": "ng build shell",
    "build:customer": "ng build customer",
    "build:supplier": "ng build supplier",
    "build:admin": "ng build admin",
    "build:frontend": "concurrently \"bun run build:shell\" \"bun run build:buyer\" \"bun run build:supplier\" \"bun run build:admin\"",
    "db:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.1",
    "@angular-devkit/build-angular": "latest",
    "@angular/cli": "^20.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "prisma"
  ]
}
