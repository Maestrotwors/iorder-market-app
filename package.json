{
  "name": "iorder-market-app",
  "version": "0.0.1",
  "private": true,
  "description": "iOrder Market — e-commerce platform",
  "workspaces": [
    "packages/*",
    "microservices/*"
  ],
  "scripts": {
    "start:web": "ng serve web",
    "start:frontend": "bun run start:web",
    "start:gateway": "cd microservices/api-gateway && bun run dev",
    "start:products": "cd microservices/products-service && bun run dev",
    "start:auth": "cd microservices/auth-service && bun run dev",
    "start:microservices": "concurrently \"bun run start:gateway\" \"bun run start:products\" \"bun run start:auth\"",
    "start:all": "concurrently \"bun run start:microservices\" \"bun run start:frontend\"",
    "build:web": "ng build web",
    "db:generate": "prisma generate --schema=database/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=database/prisma/schema.prisma",
    "db:push": "prisma db push --schema=database/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=database/prisma/schema.prisma",
    "db:seed:test-user": "bun database/scripts/seed-test-user.ts",
    "env:generate": "bun scripts/generate-env.ts && bun scripts/generate-helm-ports.ts",
    "db:up": "docker compose -f infrastructure/docker/docker-compose.db.yml up -d",
    "db:down": "docker compose -f infrastructure/docker/docker-compose.db.yml down",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.db.yml -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.db.yml -f infrastructure/docker/docker-compose.yml down",
    "dev:docker:up": "docker compose -f infrastructure/docker/docker-compose.dev.yml up -d --build",
    "dev:docker:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yml logs -f",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json}\"",
    "test:web": "bunx vitest run --config frontend/web/vite.config.ts",
    "test:web:watch": "bunx vitest watch --config frontend/web/vite.config.ts",
    "test:api": "bunx vitest run --config e2e/api/vitest.config.ts",
    "test:api:watch": "bunx vitest watch --config e2e/api/vitest.config.ts",
    "test:e2e": "bunx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "bunx playwright test --config e2e/playwright.config.ts --ui",
    "test:e2e:headed": "bunx playwright test --config e2e/playwright.config.ts --headed",
    "test:e2e:report": "bunx playwright show-report e2e/playwright-report",
    "test:e2e:docker": "docker compose -f infrastructure/docker/docker-compose.test.yml --profile e2e up --build --abort-on-container-exit e2e-runner; docker compose -f infrastructure/docker/docker-compose.test.yml --profile e2e down -v",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "check": "bun run format:check && bun run lint && bun run knip",
    "check:fix": "bun run format && bun run lint:fix && bun run knip:fix",
    "prebuild:web": "bun run check",
    "k8s:deploy": "bash scripts/k8s-deploy.sh",
    "k8s:deploy:frontend": "bash scripts/k8s-deploy-frontend.sh",
    "k8s:pods": "kubectl get pods -o wide",
    "k8s:logs": "kubectl logs -l app.kubernetes.io/part-of=iorder-market --tail=50",
    "k8s:forward": "kubectl port-forward svc/iorder-market-api-gateway 30080:3000",
    "k8s:stop": "helm uninstall iorder-market; pkill -f 'port-forward.*iorder' || true",
    "argocd": "bash scripts/argocd-setup.sh",
    "argocd:watch": "bash scripts/argocd-watch.sh",
    "monitoring": "bash scripts/monitoring-setup.sh",
    "monitoring:grafana": "kubectl port-forward svc/prometheus-stack-grafana -n monitoring 3100:80",
    "observability": "bash scripts/observability-setup.sh",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@ngrx/signals": "^21.0.1",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@analogjs/vitest-angular": "^2.3.1",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@playwright/test": "^1.58.2",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/node": "^22.0.0",
    "angular-eslint": "^21.3.1",
    "concurrently": "^9.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.0.1",
    "knip": "^5.88.0",
    "prettier": "^3.8.1",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,html,scss,json}": "prettier --write",
    "*.ts": "eslint --fix"
  },
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@prisma/client",
    "@prisma/engines",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "prisma"
  ]
}
